# Vercel 生产环境变量配置示例
# 在 Vercel Dashboard → Project Settings → Environment Variables 中设置

# Required
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres
AUTH_SECRET=
ADMIN_PASSWORD=

# Optional
# Vercel 会自动注入 VERCEL_URL / VERCEL_PROJECT_PRODUCTION_URL。
# 只有绑定自定义域名、或需要手动覆盖 canonical URL 时再设置。
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# 管理员账号邮箱可选，不设置时默认 admin@example.com
ADMIN_EMAIL=admin@example.com

# 外部 revalidate API 可选；不主动从后台功能调用。
REVALIDATE_SECRET=

# Analytics & Monetization (可选)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_TAWKTO_PROPERTY_ID=
NEXT_PUBLIC_TAWKTO_WIDGET_ID=

# Tool submission form (可选)
NEXT_PUBLIC_GOOGLE_FORM_URL=https://forms.gle/XXXXXXXXX
