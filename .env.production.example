# Vercel 生产环境变量配置示例
# 在 Vercel Dashboard → Project Settings → Environment Variables 中设置

DB_DRIVER=postgres
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# NextAuth (在 Vercel 中 AUTH_SECRET 和 NEXTAUTH_SECRET 二选一)
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://your-domain.vercel.app

NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
REVALIDATE_SECRET=

# Analytics & Monetization (可选)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_TAWKTO_PROPERTY_ID=
NEXT_PUBLIC_TAWKTO_WIDGET_ID=

# Tool submission form (可选)
NEXT_PUBLIC_GOOGLE_FORM_URL=https://forms.gle/XXXXXXXXX
