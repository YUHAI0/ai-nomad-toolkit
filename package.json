{
  "name": "ai-nomad-toolkit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node -e \"if(process.env.DATABASE_URL){const {execSync}=require('child_process');execSync('npx drizzle-kit migrate --config=drizzle.pg.config.ts',{stdio:'inherit'})}else if(process.env.VERCEL){throw new Error('[prebuild] DATABASE_URL is required on Vercel.')}else{console.log('[prebuild] DATABASE_URL not set, skipping migration.')}\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "migrate:json": "tsx scripts/migrate-json-to-db.ts",
    "drizzle:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "drizzle:generate:pg": "drizzle-kit generate --config=drizzle.pg.config.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.21.0",
    "nanoid": "^5.1.15",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
